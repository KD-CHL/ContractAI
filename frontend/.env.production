# Production API base URL
# When a backend is deployed, set the full URL here, e.g.:
# VITE_API_BASE_URL=https://your-backend.example.com/api/v1
# Leave empty to use relative path (same-origin, requires backend proxy)
VITE_API_BASE_URL=

# Demo mode: skip login, enter UI directly with a mock user
VITE_DEMO_MODE=true
