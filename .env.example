# ContractGuard configuration template. Values in this file are examples only.
# Prefer environment variables or a secret manager for credentials in production.
# Local development automatically reads .env.local; process variables take priority.

# offline: deterministic local rules; hybrid: local rules plus configured OpenAI review/OCR.
APP_MODE=offline

# AI provider (required only in hybrid mode)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna
# OPENAI_BASE_URL=
CONTRACT_GUARD_OPENAI_TIMEOUT_SECONDS=60
CONTRACT_GUARD_OPENAI_MAX_RETRIES=2

# Local persistence. The default path is mounted as a Docker volume.
DATABASE_URL=sqlite:///./data/contractguard.db

# Optional knowledge service used only in hybrid mode. Do not append /query.
# LIGHTRAG_BASE_URL=https://lightrag.example.internal
# LIGHTRAG_API_KEY=

# Runtime settings
LOG_LEVEL=info
HOST=0.0.0.0
PORT=8010

# Built-in API controls
CONTRACT_GUARD_ENV=development
# CONTRACT_GUARD_ENV_FILE=.env.local
CONTRACT_GUARD_API_PREFIX=/api/v1
CONTRACT_GUARD_KNOWLEDGE_PATH=resources/demo_knowledge_base.json
CONTRACT_GUARD_MAX_UPLOAD_BYTES=20971520
CONTRACT_GUARD_MAX_DOCUMENT_PAGES=200
CONTRACT_GUARD_MAX_DOCUMENT_CHARACTERS=1000000
CONTRACT_GUARD_MAX_DOCX_UNCOMPRESSED_BYTES=104857600
CONTRACT_GUARD_MAX_OCR_PIXELS=20000000
CONTRACT_GUARD_CACHE_TTL_SECONDS=3600
CONTRACT_GUARD_CORS_ORIGINS=
CONTRACT_GUARD_DOCS_ENABLED=true

# Local account authentication and RBAC are enabled by default.
# Keep COOKIE_SECURE=false only for local HTTP; set it to true behind production HTTPS.
CONTRACT_GUARD_AUTH_REQUIRED=true
CONTRACT_GUARD_REGISTRATION_ENABLED=true
CONTRACT_GUARD_AUTH_ACCESS_TTL_MINUTES=480
CONTRACT_GUARD_AUTH_REFRESH_TTL_DAYS=30
CONTRACT_GUARD_AUTH_COOKIE_SECURE=false
CONTRACT_GUARD_LOGIN_ATTEMPT_LIMIT=10
CONTRACT_GUARD_LOGIN_WINDOW_SECONDS=300

# Legacy compatibility only; these are used when authentication is explicitly disabled.
CONTRACT_GUARD_DEFAULT_ORG_ID=default
CONTRACT_GUARD_DEFAULT_SESSION_ID=anonymous
# Unsafe multi-tenant test compatibility. Never enable on a shared or public service.
CONTRACT_GUARD_LEGACY_TENANT_HEADERS_ENABLED=false

# Optional compatibility overrides
# CONTRACT_GUARD_SQLITE_PATH=./data/contractguard.db
# CONTRACT_GUARD_LLM_ENABLED=false
# CONTRACT_GUARD_OPENAI_MODEL=gpt-5.6-luna
# CONTRACT_GUARD_OPENAI_BASE_URL=
